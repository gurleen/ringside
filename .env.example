# Supabase connection (server-side only; not exposed to the browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx

# Production (Cloudflare Workers): set the same keys as secrets, not in wrangler.jsonc:
#   bunx wrangler secret put SUPABASE_URL
#   bunx wrangler secret put SUPABASE_ANON_KEY

# Auth: add these redirect URLs in Supabase Dashboard → Authentication → URL Configuration
# Site URL: http://localhost:3000
# Redirect URLs: http://localhost:3000/auth/confirm
# (Also add your production origin + /auth/confirm when deploying.)
